<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mayor global coordinator daemon for agent orchestration -->
    <!-- Install: launchctl load ~/Library/LaunchAgents/com.dotfiles.gwt-mayor.plist -->
    <!-- Remove:  launchctl unload ~/Library/LaunchAgents/com.dotfiles.gwt-mayor.plist -->

    <key>Label</key>
    <string>com.dotfiles.gwt-mayor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>exec $HOME/dotfiles/scripts/gwt-mayor.sh run</string>
    </array>

    <!-- Auto-start on login so mayor monitors all agents without intervention -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart if daemon crashes -->
    <key>KeepAlive</key>
    <true/>

    <!-- Prevent rapid restart loops (30s minimum between restarts) -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/tmp/gwt-mayor-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/gwt-mayor-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/shahe</string>
    </dict>
</dict>
</plist>
