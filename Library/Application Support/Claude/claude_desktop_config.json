{
  "mcpServers": {
    "playwright": {
      "command": "bunx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "steampipe": {
      "command": "bunx",
      "args": [
        "-y",
        "@turbot/steampipe-mcp",
        "postgresql://steampipe@localhost:9193/steampipe"
      ]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse",
      "transport": "sse"
    }
  }
}
