{
  "mcpServers": {
    "playwright": {
      "command": "bunx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "steampipe": {
      "command": "bunx",
      "args": [
        "-y",
        "@turbot/steampipe-mcp",
        "postgresql://steampipe@localhost:9193/steampipe"
      ]
    },
    "drawio": {
      "command": "bunx",
      "args": [
        "drawio-mcp-server"
      ]
    },
    "claudecodebrowser": {
      "command": "python3",
      "args": [
        "~/.claudecodebrowser/mcp-server/stdio_wrapper.py"
      ]
    }
  },
  "preferences": {
    "coworkScheduledTasksEnabled": false,
    "sidebarMode": "chat"
  }
}
