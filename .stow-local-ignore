# Files to ignore when stowing
\.git
\.gitignore
\.gitmodules
\.github
README.*
LICENSE
.*\.md$
.*\.swp
.*\.bak
.*\.orig
scripts/
homebrew/
CLAUDE\.md

# Nix home-manager (managed by Nix, not stow)
\.config/home-manager

# Podman Machine Configs (generated by podman, frequently change)
\.config/containers/podman/machine/applehv/.*\.ign$
\.config/containers/podman/machine/applehv/.*\.json$

# Starship config (may be customized locally)
\.config/starship\.toml

# Tmux Session State (dynamically generated)
\.tmux/resurrect/last$

# Test and Debug Files
^/test.*
^/debug.*
^/hello\.txt$
^/blah\.blah$
^/Untitled$
^/nix$
^/generated-diagrams$
^/test-data$
^/tools\.md$
^/latex\.md$

# Temporary Files
\.DS_Store
.*~$
\.tmp$
.*\.cache
