# Files to ignore when stowing
\.git
\.gitignore
\.gitmodules
\.github
README.*
LICENSE
.*\.md$
.*\.swp
.*\.bak
.*\.orig
scripts/
homebrew/
CLAUDE\.md
AGENTS\.md

# Nix home-manager (managed by Nix, not stow)
\.config/home-manager

# Nix profile (absolute symlink managed by Nix)
\.nix-profile

# Neovim (manual symlink to ~/neovim, not managed by stow)
\.config/nvim

# Podman Machine Configs (generated by podman, frequently change)
\.config/containers/podman/machine/applehv/.*\.ign$
\.config/containers/podman/machine/applehv/.*\.json$

# Starship config (may be customized locally)
\.config/starship\.toml

# Tmux Session State (dynamically generated)
\.tmux/resurrect/last$

# Tmux Plugins (managed by TPM, not stow)
\.tmux/plugins

# Build/CI files (not config, not symlinked)
Makefile
^/\.beads$

# Test and Debug Files
^/test.*
^/debug.*
^/hello\.txt$
^/blah\.blah$
^/Untitled$
^/nix$
^/generated-diagrams$
^/test-data$
^/tools\.md$
^/latex\.md$

# Temporary Files
\.DS_Store
.*~$
\.tmp$
.*\.cache

# Direnv envrc (not needed at home directory level, avoids 1.4s cd delay)
\.envrc

# Direnv Cache (machine-specific, generated by direnv)
\.direnv

# Python virtual environments
\.venv

# Playwright MCP (generated screenshots)
\.playwright-mcp

# Work directory (temporary worktree artifacts)
^/work$

# Devcontainer configs (used in-place, not symlinked to home)
^/devcontainer$

# Docs directory (documentation, not symlinked)
^/docs$

# Tmux resurrect trash (session state, not config)
\.tmux/resurrect/trash

# OrbStack Fish Completions (managed by OrbStack, absolute symlinks)
\.config/fish/completions/docker\.fish
\.config/fish/completions/orbctl\.fish
