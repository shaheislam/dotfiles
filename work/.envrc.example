#!/usr/bin/env bash
# Example .envrc for work projects with 1Password integration

# Check and load 1Password secrets
with_op op_load "Personal/Linear/api_key" "LINEAR_API_KEY"
with_op op_load "Personal/GitHub/token" "GITHUB_TOKEN"
with_op op_load "Work/OpenAI/api_key" "OPENAI_API_KEY"

# Local development settings
export NODE_ENV="development"
export PORT="3000"

# Node.js project setup
layout node

# Add local bin to PATH
PATH_add bin

# Python project setup (if needed)
# layout python python3.11

# Go project setup (if needed)
# layout go

# Ruby project setup (if needed)
# layout ruby