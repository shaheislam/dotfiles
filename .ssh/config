# 1Password SSH Agent for all connections
Host *
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Personal GitHub account  
Host github.com-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislam-github.pub
    IdentitiesOnly yes
    PreferredAuthentications publickey

# DFE GitHub account
Host github.com-dfe
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislamdfe.pub
    IdentitiesOnly yes

# Bitbucket (Home Office) - Using 1Password agent
Host bitbucket.bics-collaboration.homeoffice.gov.uk
    HostName bitbucket.bics-collaboration.homeoffice.gov.uk
    User git
    IdentitiesOnly yes
    PreferredAuthentications publickey

# Default github.com
Host github.com
    HostName github.com
    User git