# Colima SSH config (if exists)
Include ~/.colima/ssh_config

# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# Include all config files from config.d/
Include config.d/*

# macOS Keychain integration for SSH keys
Host *
    IgnoreUnknown UseKeychain
    UseKeychain yes
    AddKeysToAgent yes

# Default GitHub access (personal)
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislam-github
    IdentitiesOnly yes

# Personal GitHub account
Host github.com-personal github-shaheislam
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislam-github
    IdentitiesOnly yes
    PreferredAuthentications publickey

# Bitbucket (Home Office)
Host bitbucket.bics-collaboration.homeoffice.gov.uk
    HostName bitbucket.bics-collaboration.homeoffice.gov.uk
    User git
    IdentityFile ~/.ssh/bitbucket
    IdentitiesOnly yes
    PreferredAuthentications publickey

# Bitbucket (Home Office)
Host bitbucket.ipttools.info
    HostName bitbucket.ipttools.info
    User git
    IdentityFile ~/.ssh/bitbucket
    IdentitiesOnly yes
    PreferredAuthentications publickey

# GitLab (fw-thorpe / Petlab)
Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab
    IdentitiesOnly yes
    PreferredAuthentications publickey

# EC2 instances via SSM
Host i-* mi-*
    ProxyCommand sh -c "AWS_PROFILE=${AWS_PROFILE:-labs} aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
    User root
    IdentityFile ~/.ssh/shahe-distant-nvim
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

# Kubernetes pods via kubectl (requires SSH server in pod)
Host k8s-*
    ProxyCommand sh -c "pod=$(echo %h | sed 's/k8s-//'); kubectl port-forward $pod 0:22 2>/dev/null"
    User root
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
