use flake path:$HOME/dotfiles/nix/global

# Load mise after Nix to ensure mise-managed tools take precedence
# direnv evaluates .envrc in bash, so we use 'bash' here (not 'fish' or 'direnv')
PROMPT_COMMAND="${PROMPT_COMMAND:-}"
eval "$(mise activate bash)"

# --- GWT_PORTS_BEGIN ---
# Auto-injected by gwt-dev. Remove this block to opt out.
test -f .env.ports && dotenv .env.ports
test -f .env.db && dotenv .env.db
# --- GWT_PORTS_END ---
