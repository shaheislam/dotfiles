#!/bin/bash

# CV Generation Wrapper Script
# This script provides a simple interface to the Python CV generator
# Usage: cv-generate <recruiter> <date> <type> <salary> [options]

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored messages
print_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_info() { echo -e "${YELLOW}[INFO]${NC} $1"; }
print_debug() { [ "$DEBUG" = "1" ] && echo -e "${BLUE}[DEBUG]${NC} $1"; }

# Script location
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PYTHON_SCRIPT="$SCRIPT_DIR/cv-generator.py"
CONFIG_FILE="$SCRIPT_DIR/cv-config.yaml"

# Check Python installation
if ! command -v python3 &> /dev/null; then
    print_error "Python 3 is not installed"
    exit 1
fi

# Check if Python script exists
if [ ! -f "$PYTHON_SCRIPT" ]; then
    print_error "CV generator Python script not found: $PYTHON_SCRIPT"
    exit 1
fi

# Check if config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    print_error "Configuration file not found: $CONFIG_FILE"
    exit 1
fi

# Function to show usage
show_usage() {
    cat << EOF
Usage: cv-generate <recruiter> <date> <type> <salary> [options]

Generate a tailored CV based on job requirements and parameters.

Arguments:
    recruiter    Recruiter company name (e.g., lorien, experis, hays)
    date         Date in DDMMYY format (e.g., 070125)
    type         Job type: perm, contract, or temp
    salary       Salary/rate (e.g., 80k for permanent, 700 for contract)

Options:
    --format tex       Generate LaTeX only (default: pdf)
    --output NAME      Custom output filename (without extension)
    --compiler NAME    LaTeX compiler: pdflatex, xelatex, lualatex (default: pdflatex)
    --no-cleanup       Keep auxiliary LaTeX files
    --open             Open PDF after generation
    --verbose          Enable verbose output
    --debug            Enable debug mode
    --help, -h         Show this help message

Examples:
    cv-generate experis 070125 perm 80k
    cv-generate lorien 070125 contract 700
    cv-generate hays 070125 perm 90k --open
    cv-generate experis 070125 contract 650 --format tex
    cv-generate lorien 070125 perm 85k --output CustomCV --compiler xelatex

Environment Variables:
    DEBUG=1            Enable debug output
    CV_CONFIG          Path to alternative config file

EOF
}

# Parse command line arguments
if [ $# -lt 4 ]; then
    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        show_usage
        exit 0
    fi
    print_error "Insufficient arguments"
    show_usage
    exit 1
fi

# Required arguments
RECRUITER="$1"
DATE="$2"
TYPE="$3"
SALARY="$4"
shift 4

# Optional arguments with defaults
FORMAT="pdf"
OUTPUT_NAME=""
COMPILER="pdflatex"
NO_CLEANUP=""
OPEN_PDF=""
VERBOSE=""
DEBUG="${DEBUG:-0}"

# Parse optional arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --format)
            FORMAT="$2"
            shift 2
            ;;
        --output)
            OUTPUT_NAME="$2"
            shift 2
            ;;
        --compiler)
            COMPILER="$2"
            shift 2
            ;;
        --no-cleanup)
            NO_CLEANUP="1"
            shift
            ;;
        --open)
            OPEN_PDF="1"
            shift
            ;;
        --verbose)
            VERBOSE="1"
            shift
            ;;
        --debug)
            DEBUG="1"
            shift
            ;;
        --help|-h)
            show_usage
            exit 0
            ;;
        *)
            print_error "Unknown option: $1"
            show_usage
            exit 1
            ;;
    esac
done

# Validate required arguments
print_info "Validating parameters..."

# Validate date format (DDMMYY)
if ! [[ "$DATE" =~ ^[0-9]{6}$ ]]; then
    print_error "Invalid date format. Use DDMMYY (e.g., 070125)"
    exit 1
fi

# Validate job type
if [[ ! "$TYPE" =~ ^(perm|contract|temp)$ ]]; then
    print_error "Invalid job type. Use: perm, contract, or temp"
    exit 1
fi

# Validate format
if [[ ! "$FORMAT" =~ ^(pdf|tex)$ ]]; then
    print_error "Invalid format. Use: pdf or tex"
    exit 1
fi

# Validate compiler
if [[ ! "$COMPILER" =~ ^(pdflatex|xelatex|lualatex)$ ]]; then
    print_error "Invalid compiler. Use: pdflatex, xelatex, or lualatex"
    exit 1
fi

# Build Python command
PYTHON_CMD="python3 $PYTHON_SCRIPT"
PYTHON_CMD="$PYTHON_CMD $RECRUITER $DATE $TYPE $SALARY"

# Add optional flags
[ "$FORMAT" = "tex" ] && PYTHON_CMD="$PYTHON_CMD --format tex"
[ -n "$OUTPUT_NAME" ] && PYTHON_CMD="$PYTHON_CMD --output $OUTPUT_NAME"
[ "$COMPILER" != "pdflatex" ] && PYTHON_CMD="$PYTHON_CMD --compiler $COMPILER"
[ "$NO_CLEANUP" = "1" ] && PYTHON_CMD="$PYTHON_CMD --no-cleanup"
[ "$OPEN_PDF" = "1" ] && PYTHON_CMD="$PYTHON_CMD --open"
[ "$VERBOSE" = "1" ] && PYTHON_CMD="$PYTHON_CMD --verbose"
[ "$DEBUG" = "1" ] && PYTHON_CMD="$PYTHON_CMD --debug"

# Use alternative config if specified
[ -n "$CV_CONFIG" ] && PYTHON_CMD="$PYTHON_CMD --config $CV_CONFIG"

# Display command in debug mode
print_debug "Executing: $PYTHON_CMD"

# Execute Python script
print_info "Generating CV for $RECRUITER (Date: $DATE, Type: $TYPE, Salary: $SALARY)..."

if $PYTHON_CMD; then
    print_success "CV generation completed successfully!"
    
    # Show output location if PDF was generated
    if [ "$FORMAT" = "pdf" ]; then
        if [ -n "$OUTPUT_NAME" ]; then
            OUTPUT_FILE="$HOME/Documents/jobapps/output/${OUTPUT_NAME}.pdf"
        else
            OUTPUT_FILE="$HOME/Documents/jobapps/output/CV_${RECRUITER}_${DATE}_${TYPE}.pdf"
        fi
        
        if [ -f "$OUTPUT_FILE" ]; then
            print_info "Output: $OUTPUT_FILE"
            print_info "Size: $(du -h "$OUTPUT_FILE" | cut -f1)"
            
            # Open PDF if requested
            if [ "$OPEN_PDF" = "1" ]; then
                print_info "Opening PDF..."
                open "$OUTPUT_FILE" 2>/dev/null || xdg-open "$OUTPUT_FILE" 2>/dev/null || print_error "Could not open PDF automatically"
            fi
        fi
    fi
else
    print_error "CV generation failed"
    exit 1
fi

exit 0