#!/usr/bin/env bash

# Wrapper to run Claude CLI under Node 20, regardless of the global Node
set -euo pipefail

# Resolve Node 20 location (Homebrew prefixes)
NODE20_DIR=""
if [[ -x "/opt/homebrew/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/opt/homebrew/opt/node@20/bin"
elif [[ -x "/usr/local/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/usr/local/opt/node@20/bin"
elif [[ -x "/home/linuxbrew/.linuxbrew/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/home/linuxbrew/.linuxbrew/opt/node@20/bin"
fi

if [[ -z "$NODE20_DIR" ]]; then
  echo "Node 20 not found. Install with: brew install node@20" >&2
  exit 1
fi

# Locate the real Claude binary
REAL_CLAUDE=""

# 1) Preferred local installs
if [[ -x "$HOME/.claude/local/bin/claude" ]]; then
  REAL_CLAUDE="$HOME/.claude/local/bin/claude"
elif [[ -x "$HOME/.claude/local/node_modules/.bin/claude" ]]; then
  REAL_CLAUDE="$HOME/.claude/local/node_modules/.bin/claude"
fi

# 2) Common user-local location
if [[ -z "$REAL_CLAUDE" && -x "$HOME/.local/bin/claude" && "$HOME/.local/bin/claude" != "$0" ]]; then
  REAL_CLAUDE="$HOME/.local/bin/claude"
fi

# 3) Homebrew locations
if [[ -z "$REAL_CLAUDE" ]]; then
  for CAND in \
    "/opt/homebrew/bin/claude" \
    "/usr/local/bin/claude"; do
    if [[ -x "$CAND" && "$CAND" != "$0" ]]; then
      REAL_CLAUDE="$CAND"
      break
    fi
  done
fi

# 4) Any other PATH occurrence (skip this wrapper)
if [[ -z "$REAL_CLAUDE" ]]; then
  while IFS= read -r CAND; do
    if [[ "$CAND" != "$0" && -x "$CAND" ]]; then
      REAL_CLAUDE="$CAND"
      break
    fi
  done < <(command -v -a claude 2>/dev/null | awk 'notseen[$0]++')
fi

if [[ -z "$REAL_CLAUDE" || ! -x "$REAL_CLAUDE" ]]; then
  echo "Claude CLI not found. Install from https://claude.ai/download or ensure ~/.claude/local/node_modules/.bin/claude exists." >&2
  exit 1
fi

# Ensure Node 20 is picked first for this process only
export PATH="$NODE20_DIR:$PATH"
exec "$REAL_CLAUDE" "$@"
