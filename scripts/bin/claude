#!/usr/bin/env bash

# Wrapper to run Claude CLI under Node 20, regardless of the global Node
# Uses ONLY Homebrew-installed Claude Code to avoid conflicts with npm/local installs
set -euo pipefail

# Resolve Node 20 location (Homebrew prefixes)
NODE20_DIR=""
if [[ -x "/opt/homebrew/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/opt/homebrew/opt/node@20/bin"
elif [[ -x "/usr/local/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/usr/local/opt/node@20/bin"
elif [[ -x "/home/linuxbrew/.linuxbrew/opt/node@20/bin/node" ]]; then
  NODE20_DIR="/home/linuxbrew/.linuxbrew/opt/node@20/bin"
fi

if [[ -z "$NODE20_DIR" ]]; then
  echo "Node 20 not found. Install with: brew install node@20" >&2
  exit 1
fi

# Locate the Homebrew Claude binary (only source - no fallbacks to npm/local)
REAL_CLAUDE=""
for CAND in "/opt/homebrew/bin/claude" "/usr/local/bin/claude"; do
  if [[ -x "$CAND" && "$CAND" != "$0" ]]; then
    REAL_CLAUDE="$CAND"
    break
  fi
done

if [[ -z "$REAL_CLAUDE" || ! -x "$REAL_CLAUDE" ]]; then
  echo "Claude CLI not found. Install with: brew install --cask claude-code" >&2
  exit 1
fi

# Ensure Node 20 is picked first for this process only
export PATH="$NODE20_DIR:$PATH"
exec "$REAL_CLAUDE" "$@"
