#!/usr/bin/env bash
# Event-driven Claude wrapper for tmux agent state tracking.
#
# Default behavior prefers the native Claude install (via `claude install`). If
# the native binary is missing we fall back to bunx (`@anthropic-ai/claude-code`).
# Set CLAUDE_RUNNER=bunx to force the package runner, or CLAUDE_RUNNER=native to
# skip the auto-detection logic entirely.
#
# Inside tmux we still export TMUX_AGENT_TARGET so hooks can color the pane.

set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SELF_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
CLAUDE_RUNNER="${CLAUDE_RUNNER:-auto}"
PASSTHRU_CMDS=(mcp config plugin auth doctor update api-key logout migrate-installer)

canonicalize_path() {
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1"
}

find_real_claude() {
    local IFS=':'
    for dir in $PATH; do
        [[ "$dir" == "$SELF_DIR" ]] && continue
        local candidate="$dir/claude"
        if [[ -x "$candidate" && ! -d "$candidate" ]]; then
            local candidate_real
            candidate_real="$(canonicalize_path "$candidate")"
            [[ "$candidate_real" == "$SELF_PATH" ]] && continue
            echo "$candidate"
            return 0
        fi
    done
    echo "claude wrapper: real binary not found in PATH" >&2
    return 1
}

is_passthrough_command() {
    for arg in "$@"; do
        case "$arg" in
            -*) continue ;;
            *)
                for cmd in "${PASSTHRU_CMDS[@]}"; do
                    if [[ "$arg" == "$cmd" ]]; then
                        return 0
                    fi
                done
                break
                ;;
        esac
    done
    return 1
}

uses_resume_flag() {
    for arg in "$@"; do
        case "$arg" in
            --resume|--resume=*|-r|-r*)
                return 0
                ;;
        esac
    done
    return 1
}

run_native() {
    local real
    if [[ -n "${CLAUDE_NATIVE_PATH:-}" ]]; then
        real="$CLAUDE_NATIVE_PATH"
    else
        real=$(find_real_claude) || exit 1
    fi

    if [[ -z "${TMUX:-}" ]]; then
        exec "$real" "$@"
    fi

    if is_passthrough_command "$@"; then
        exec "$real" "$@"
    fi

    export TMUX_AGENT_TARGET
    TMUX_AGENT_TARGET=$(tmux display-message -p '#{window_id}' 2>/dev/null) || true
    exec "$real" "$@"
}

run_bunx() {
    local bunx_bin
    bunx_bin="${CLAUDE_BUNX_BIN:-$(command -v bunx 2>/dev/null || true)}"
    if [[ -z "$bunx_bin" ]]; then
        echo "claude wrapper: bunx not found (install bun via Homebrew)" >&2
        exit 1
    fi

    local latest_pkg="${CLAUDE_PACKAGE_LATEST:-@anthropic-ai/claude-code@latest}"
    local resume_pkg="${CLAUDE_PACKAGE_RESUME:-@anthropic-ai/claude-code@2.1.30}"
    local package="$latest_pkg"

    if uses_resume_flag "$@" && [[ "${CLAUDE_RESUME_ROUTING:-on}" != "off" ]]; then
        package="$resume_pkg"
        if [[ -z "${CLAUDE_WRAPPER_QUIET:-}" ]]; then
            >&2 echo "claude wrapper: routing --resume via $package to avoid cache rebuilds"
        fi
    fi

    if [[ -z "${TMUX:-}" ]]; then
        exec "$bunx_bin" "$package" "$@"
    fi

    if is_passthrough_command "$@"; then
        exec "$bunx_bin" "$package" "$@"
    fi

    export TMUX_AGENT_TARGET
    TMUX_AGENT_TARGET=$(tmux display-message -p '#{window_id}' 2>/dev/null) || true
    exec "$bunx_bin" "$package" "$@"
}

case "$CLAUDE_RUNNER" in
    native)
        run_native "$@"
        ;;
    bunx)
        run_bunx "$@"
        ;;
    auto)
        if CLAUDE_NATIVE_PATH=$(find_real_claude 2>/dev/null); then
            CLAUDE_NATIVE_PATH="$CLAUDE_NATIVE_PATH" run_native "$@"
        else
            run_bunx "$@"
        fi
        ;;
    *)
        run_bunx "$@"
        ;;
esac
