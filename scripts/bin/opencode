#!/usr/bin/env bash
set -euo pipefail

# OpenTUI probes Kitty graphics support by default. In tmux panes that reply can
# occasionally leak into Fish as `Gi=31337;OK`; keep image probing off for
# OpenCode while leaving terminal graphics enabled for other apps.
export OPENTUI_GRAPHICS="${OPENTUI_GRAPHICS:-0}"

SELF_PATH="${BASH_SOURCE[0]}"
if command -v realpath >/dev/null 2>&1; then
	SELF_PATH="$(realpath "$SELF_PATH")"
fi

find_real_ocv() {
	local candidate candidate_real
	for candidate in /opt/homebrew/bin/ocv /usr/local/bin/ocv "$HOME/.local/bin/ocv" "$HOME/.bun/bin/ocv"; do
		[ -x "$candidate" ] || continue
		candidate_real="$candidate"
		if command -v realpath >/dev/null 2>&1; then
			candidate_real="$(realpath "$candidate")"
		fi
		[ "$candidate_real" != "$SELF_PATH" ] || continue
		printf '%s\n' "$candidate"
		return 0
	done
	return 1
}

should_wrap_in_tmux() {
	[ -n "${TMUX:-}" ] || return 1
	[ -z "${OPENCODE_TMUX_WRAPPER_ACTIVE:-}" ] || return 1

	case "${1:-}" in
	"" | attach)
		return 0
		;;
	run | serve | --help | -h | help | --version | version)
		return 1
		;;
	-*)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

if should_wrap_in_tmux "${1:-}"; then
	exec "$HOME/dotfiles/scripts/opencode/tmux-open.sh" "$@"
fi

if ocv_bin="$(find_real_ocv)"; then
	exec "$ocv_bin" "$@"
fi

printf 'opencode shim: ocv is not installed. Run: brew install leohenon/tap/ocv\n' >&2
exit 127
