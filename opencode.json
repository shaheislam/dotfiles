{
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["bunx", "-y", "@playwright/mcp@latest"]
    },
    "steampipe": {
      "type": "local",
      "command": ["bunx", "-y", "@turbot/steampipe-mcp", "postgresql://steampipe@localhost:9193/steampipe"]
    },
    "context7": {
      "type": "local",
      "command": ["bunx", "-y", "@upstash/context7-mcp"]
    },
    "drawio": {
      "type": "local",
      "command": ["bunx", "-y", "drawio-mcp-server"]
    },
    "claudecodebrowser": {
      "type": "local",
      "command": ["python3", "~/.claudecodebrowser/mcp-server/stdio_wrapper.py"]
    }
  }
}
