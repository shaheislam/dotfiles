# Activate the Terraform project flake
use flake

# Optional: Set Terraform-specific environment variables
export TF_PLUGIN_CACHE_DIR="$HOME/.terraform.d/plugin-cache"
export TF_CLI_ARGS_plan="-parallelism=10"
export TF_CLI_ARGS_apply="-parallelism=10"

# Optional: Load AWS credentials from specific profile
# export AWS_PROFILE=myproject

# Optional: Set Terraform workspace
# export TF_WORKSPACE=development