{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  // Dynamic Context Pruning — @tarquinen/opencode-dcp
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "commands": {
    "enabled": true,
    "protectedTools": ["bash"]
  },
  "compress": {
    "nudgeFrequency": 10,
    "protectedTools": ["bash"]
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": ["bash"]
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": ["bash"]
    }
  }
}
