{
  // Dynamic Context Pruning — @tarquinen/opencode-dcp
  // Project-level config. See: https://github.com/Tarquinen/opencode-dynamic-context-pruning
  "compressionMode": "range",
  "maxContextLimit": 100000,
  "minContextLimit": 50000,
  "strategies": {
    "deduplication": true,
    "purgeErrors": true
  },
  "notificationStyle": "minimal",
  "protectUserMessages": true
}
