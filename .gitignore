# Local git excludes symlink (for personal, non-committed patterns)
.gitignore_local
.config/git/hooks/

# Tmux plugin manager and plugins
.tmux/plugins/

# Tmux resurrect session files (these are machine-specific)
.tmux/resurrect/
*.resurrect

# Claude Code - ignore frequently changing files but keep important configs
# Ignore session data and caches
.claude.json
.claude/ide/
.claude/todos/
.claude/shell-snapshots/
.claude/projects/
.claude/statsig/
.claude/logs/
.claude/usage/
.claude/backups/
.claude/audio/
.claude/hooks/logs/

# Ignore frequently changing log and data files
.claude/audio_hook.log
.claude/bash_commands.json
.claude/bun_enforcement.json
.claude/.superclaude-metadata.json
.claude/settings.local.json
.claude/plugins/known_marketplaces.json
.claude/plugins/marketplaces/
.claude/plugins/cache/
.claude/plugins/installed_plugins.json
.claude/hooks/__pycache__/

# Ticket execution artifacts (generated by gwt-ticket)
.claude/launch-claude.fish
.claude/setup-panes.fish
.claude/start-claude-pane.fish
.claude/*.local.md
.claude/ralph-loop.local.md

# Launch templates - machine-specific settings
.config/launch-templates/.claude/

# Keep these directories and files (they're tracked):
# .claude/agents/        - Agent configurations

# CV generation artifacts - these are all generated files
jobapps/generated/
jobapps/output/
# .claude/commands/      - Custom commands
# .claude/hooks/         - Hook scripts
# .claude/templates/     - Templates
# .claude/*.md           - Documentation files
# .claude/settings.json  - Main settings

# Neovim config (managed in separate repo at ~/neovim)
.config/nvim

# Fish shell - device-specific universal variables
.config/fish/fish_variables
.config/fish/fish_history

# macOS
.DS_Store

# Backup files
*.backup
*.bak
*.archive
*.orig
*~
.backup/
.bak/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
.pytest_cache/

# Logs
*.log
logs/
*.error.log

# Lock files
*.lock
package-lock.json

# Test files
testfolder/
test/
scripts/tests/

# SSH keys and sensitive test data
**/ssh_host_*_key
**/ssh_host_*_key.pub
**/.ssh/authorized_keys
**/sshd.pid
**/sshd_config

# Version control
.jj/

# Environment files
# Note: The global .envrc at dotfiles root is tracked (for Nix global environment)
# Project-specific .envrc files should not be committed
.direnv/
.env
.claude.json

# Kubernetes Configuration Files
# Kubeconfig files contain sensitive cluster credentials
.kube/config
.kube/config.*
.kube/cache/
.kube/http-cache/
*kubeconfig*
!.kube/config.template
!.kube/README.md

# k3d/k3s Specific
# k3d runtime files
.k3d/
k3d-*.yaml.tmp
# k3s data directories (if running k3s directly)
/var/lib/rancher/k3s/
.k3s-data/

# Minikube Specific
.minikube/
.minikube-cache/
minikube.log

# Kind (Kubernetes in Docker) Specific
.kind/
kind-logs-*/

# Helm Charts
# Helm package files that might contain secrets
**/charts/*.tgz
**/charts/*.tar.gz
**/requirements.lock

# Docker buildx state (machine-specific cache/refs)
.docker/

# Container Runtime Logs
podman-machine.log
docker-machine.log
containerd.log

# Kubernetes Tools Configuration
# kubectl plugins cache
.kubectl-plugins/

# Downloaded archives (temporary)
awscli-bundle.zip
awscli-bundle/

