[core]
	excludesfile = /Users/mohammedislam/.gitignore_global
	pager = delta

[init]
	templateDir = /Users/shaheislam/.config/git/templates

[user]
	name = Shahe Islam
	email = shaheislam@users.noreply.github.com

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	hyperlinks = true
	hyperlinks-file-link-format = "file://{path}"
	blame-code-style = syntax

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	tool = nvimdiff
	colorMoved = default

[difftool]
	prompt = false

[difftool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$REMOTE"

[pager]
	blame = delta

[alias]
	mergetool = "!nvim -c DiffviewOpen"
