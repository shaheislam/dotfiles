[core]
	excludesfile = /Users/shaheislam/.gitignore_global
	pager = delta
[user]
	email = shahedulislam94@gmail.com
	name = Mohammed Islam
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINul6AslUSv8Wda9xggr4Dt2X77BD4lbDn2TgMww0lfi
[init]
	templateDir = ~/.config/git
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
	allowedsignersfile = ~/.ssh/allowed_signers
[commit]
	gpgsign = true

# Include personal config for personal projects
[includeIf "gitdir:~/dotfiles/"]
	path = ~/dotfiles/.gitconfig-personal
[includeIf "gitdir:~/src/personal/"]
	path = ~/dotfiles/.gitconfig-personal
	
# Include DFE config for work projects
[includeIf "gitdir:~/work/"]
	path = ~/dotfiles/.gitconfig-dfe
[includeIf "gitdir:~/src/dfe/"]
	path = ~/dotfiles/.gitconfig-dfe
[interactive]
	diffFilter = delta --color-only
[delta]
	theme = Catppuccin-mocha
	line-numbers = true
	side-by-side = true
	navigate = true
	light = false
	syntax-theme = Catppuccin Mocha
	file-style = bold yellow ul
	file-decoration-style = none
	hunk-header-decoration-style = cyan box
	hunk-header-style = file line-number syntax
	line-numbers-left-format = {nm:>4}┊
	line-numbers-right-format = {np:>4}│
