[core]
	excludesfile = ~/.gitignore_global
	pager = delta
	fsmonitor = true
	untrackedCache = true

[feature]
	manyFiles = true

[fetch]
	writeCommitGraph = true

[init]
	templateDir = /Users/shaheislam/.config/git/templates

[user]
	name = Shahe Islam
	email = shaheislam@users.noreply.github.com

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	hyperlinks = true
	hyperlinks-file-link-format = "file://{path}"
	blame-code-style = syntax

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	tool = nvimdiff
	colorMoved = default

[difftool]
	prompt = false

[difftool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$REMOTE"

[pager]
	blame = delta

[alias]
	mergetool = "!nvim -c DiffviewOpen"
[filter "json-normalize"]
	clean = /Users/shaheislam/dotfiles/scripts/git-clean-json.sh
[merge "jsonl-merge"]
	name = JSONL merge for append-only line files
	driver = /Users/shahe/dotfiles/scripts/merge-driver-jsonl.sh %A %O %B %L %P
[diff "json"]
	textconv = /Users/shaheislam/dotfiles/scripts/git-diff-json.sh
[merge "union-doc"]
	name = Union merge for documentation files
	driver = /Users/shaheislam/dotfiles/scripts/merge-driver-union.sh %A %O %B %L %P
[merge "brewfile"]
	name = Union merge for Brewfile
	driver = /Users/shaheislam/dotfiles/scripts/merge-driver-brewfile.sh %A %O %B %L %P
[merge "json-merge"]
	name = Deep merge for JSON config files
	driver = /Users/shaheislam/dotfiles/scripts/merge-driver-json.sh %A %O %B %L %P
[merge "lockfile"]
	name = Keep ours for lockfiles
	driver = /Users/shaheislam/dotfiles/scripts/merge-driver-lockfile.sh %A %O %B %L %P
[diff "plist"]
	textconv = plutil -convert xml1 -o -
[maintenance]
	repo = /Users/shaheislam/dotfiles
