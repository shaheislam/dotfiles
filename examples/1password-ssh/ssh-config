# SSH Configuration for 1Password SSH Agent Integration
# This file should replace or be merged with ~/.ssh/config
# It sets up different hosts for multiple GitHub accounts

# Personal GitHub account
Host github.com-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislam-github.pub
    IdentitiesOnly yes

# DFE GitHub account (Work)
Host github.com-dfe
    HostName github.com
    User git
    IdentityFile ~/.ssh/shaheislamdfe.pub
    IdentitiesOnly yes

# Bitbucket for PetLab
Host bitbucket.org
    HostName bitbucket.org
    User git
    IdentityFile ~/.ssh/bitbucket.pub
    IdentitiesOnly yes

# Default GitHub configuration using 1Password agent
Host github.com
    HostName github.com
    User git
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    IdentitiesOnly yes

# For other SSH connections using 1Password agent
Host *
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"