# Additional configuration for main ~/.gitconfig
# Add these lines to your main git config to enable directory-based identity switching

# Include personal git config for personal projects
[includeIf "gitdir:~/src/personal/"]
    path = ~/src/personal/.gitconfig

# Include DFE git config for DFE projects
[includeIf "gitdir:~/src/dfe/"]
    path = ~/src/dfe/.gitconfig

# Include PetLab git config if needed
[includeIf "gitdir:~/src/petlab/"]
    path = ~/src/petlab/.gitconfig

# Alternative: Use different paths based on your directory structure
# [includeIf "gitdir:~/personal/"]
#     path = ~/personal/.gitconfig
#
# [includeIf "gitdir:~/work/"]
#     path = ~/work/.gitconfig