#!/usr/bin/env bash
# direnv + 1Password integration

# Logging functions
log_status() {
    echo "$1" >&2
}

log_error() {
    echo "$1" >&2
}

# Function to load secrets from 1Password
# Usage: op_load "vault/item/field" "ENV_VAR_NAME"
op_load() {
    local op_ref="$1"
    local env_var="$2"
    
    if command -v op >/dev/null 2>&1; then
        # Check if 1Password is authenticated
        if op account get >/dev/null 2>&1; then
            # Extract vault, item, and field from the reference
            # Format: vault/item/field or item/field (uses default vault)
            local value
            value=$(op read "$op_ref" 2>/dev/null)
            
            if [ $? -eq 0 ] && [ -n "$value" ]; then
                export "$env_var=$value"
                log_status "✓ Loaded $env_var from 1Password"
            else
                log_error "✗ Failed to load $env_var from 1Password"
            fi
        else
            log_error "✗ 1Password CLI not authenticated. Run: eval \$(op signin)"
        fi
    else
        log_error "✗ 1Password CLI not installed"
    fi
}

# Alternative: Use op run style references
# This allows using op://vault/item/field syntax in .env files
source_env_1password() {
    local env_file="${1:-.env.1password}"
    
    if [ -f "$env_file" ]; then
        if command -v op >/dev/null 2>&1; then
            # Process the file and export variables
            while IFS='=' read -r key value; do
                # Skip comments and empty lines
                [[ "$key" =~ ^#.*$ ]] && continue
                [[ -z "$key" ]] && continue
                
                # Remove quotes from value
                value="${value%\"}"
                value="${value#\"}"
                value="${value%\'}"
                value="${value#\'}"
                
                # Check if value is a 1Password reference
                if [[ "$value" =~ ^op://.* ]]; then
                    # Extract the reference path
                    local op_path="${value#op://}"
                    local actual_value
                    actual_value=$(op read "op://$op_path" 2>/dev/null)
                    
                    if [ $? -eq 0 ] && [ -n "$actual_value" ]; then
                        export "$key=$actual_value"
                        log_status "✓ Loaded $key from 1Password"
                    else
                        log_error "✗ Failed to load $key from 1Password"
                    fi
                else
                    # Regular environment variable
                    export "$key=$value"
                fi
            done < "$env_file"
        else
            log_error "✗ 1Password CLI not installed"
        fi
    fi
}

# Helper function to check 1Password authentication status
op_check_auth() {
    if command -v op >/dev/null 2>&1; then
        if op account get >/dev/null 2>&1; then
            log_status "✓ 1Password CLI authenticated"
            return 0
        else
            log_error "✗ 1Password CLI not authenticated"
            log_status "  Run: eval \$(op signin)"
            return 1
        fi
    else
        log_error "✗ 1Password CLI not installed"
        return 1
    fi
}

# Wrapper to ensure 1Password is available before loading
with_op() {
    if op_check_auth; then
        "$@"
    fi
}