# Ghostty Configuration - WezTerm Parity
# ~/.config/ghostty/config

# =============================================================================
# FONT
# =============================================================================
font-family = JetBrainsMono Nerd Font
font-size = 14

# Ligatures (matching WezTerm's harfbuzz_features)
font-feature = calt
font-feature = liga
font-feature = dlig
font-feature = ss01
font-feature = ss02

# =============================================================================
# THEME & APPEARANCE
# =============================================================================
theme = Catppuccin Mocha
background-opacity = 0.90
background-blur-radius = 20

# Window padding (left/right = 2, top/bottom = 0)
window-padding-x = 2
window-padding-y = 0

# Window decorations (RESIZE equivalent)
window-decoration = true
macos-titlebar-style = transparent

# =============================================================================
# CURSOR
# =============================================================================
cursor-style = block
cursor-style-blink = true

# =============================================================================
# SHELL & TERMINAL
# =============================================================================
command = /opt/homebrew/bin/fish -l
scrollback-limit = 10000
shell-integration = detect

# Disable audible bell (prevents sound on every keystroke with tmux activity monitoring)
audible-bell = false

# =============================================================================
# KEYBINDINGS - WezTerm Parity
# =============================================================================

# --- Splits ---
# CMD+d = split horizontal (right)
keybind = super+d=new_split:right
# CMD+SHIFT+d = split vertical (down)
keybind = super+shift+d=new_split:down

# --- Pane Navigation (vim-style: hjkl) ---
keybind = super+h=goto_split:left
keybind = super+l=goto_split:right
keybind = super+k=goto_split:top
keybind = super+j=goto_split:bottom

# --- Clear Scrollback (CTRL+') ---
keybind = ctrl+'=clear_screen

# --- Open Claude in new tab (CMD+a) ---
# Unbind select_all first, then bind to Claude
keybind = super+a=unbind
keybind = super+a=new_tab:/opt/homebrew/bin/fish -c claude

# --- Open Neovim (CMD+e) ---
keybind = super+e=text:nvim .\n

# --- Standard keybindings to keep ---
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+w=close_window
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+n=new_window
keybind = super+q=quit
keybind = super+enter=toggle_fullscreen
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size
keybind = super+comma=open_config
keybind = super+shift+comma=reload_config

# Tab navigation
keybind = super+shift+left_bracket=previous_tab
keybind = super+shift+right_bracket=next_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = super+physical:one=goto_tab:1
keybind = super+physical:two=goto_tab:2
keybind = super+physical:three=goto_tab:3
keybind = super+physical:four=goto_tab:4
keybind = super+physical:five=goto_tab:5
keybind = super+physical:six=goto_tab:6
keybind = super+physical:seven=goto_tab:7
keybind = super+physical:eight=goto_tab:8
keybind = super+physical:nine=last_tab

# Pane resize
keybind = super+ctrl+left=resize_split:left,10
keybind = super+ctrl+right=resize_split:right,10
keybind = super+ctrl+up=resize_split:up,10
keybind = super+ctrl+down=resize_split:down,10
keybind = super+ctrl+equal=equalize_splits
keybind = super+shift+enter=toggle_split_zoom
