# Shared Codex app open-destination settings.
#
# These values are tracked in dotfiles so Codex app behavior stays consistent
# across Macs. The generated .app bundle in /Applications is machine-local.
#
# Identity must be an editor Codex already allowlists and that you do not use as
# a real app on this machine.
CODEX_OPEN_DESTINATION_IDENTITY_NAME="TextMate"
CODEX_OPEN_DESTINATION_BUNDLE_ID="com.macromates.TextMate"

# Route modes:
#   default-handler  -> use the normal macOS default app for each file
#   open-app         -> always use `open -a <TARGET_APP>`
#   shell-command    -> run TARGET_COMMAND <file>
CODEX_OPEN_DESTINATION_ROUTE_MODE="shell-command"

# Used when ROUTE_MODE=open-app
CODEX_OPEN_DESTINATION_TARGET_APP=""

# Used when ROUTE_MODE=shell-command
# Examples:
#   open -a Alacritty --args -e nvim
#   $DOTFILES_ROOT/scripts/codex/open-tmux-nvim.sh
#   /opt/homebrew/bin/zed
#   /usr/local/bin/idea -e
CODEX_OPEN_DESTINATION_TARGET_COMMAND="$DOTFILES_ROOT/scripts/codex/open-tmux-nvim.sh"
