{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "blue": "#b8d9fc",
    "cyan": "#b4e2c7",
    "purple": "#d7cef9",
    "green": "#d3daad",
    "orange": "#fac6c1",
    "red": "#f1c6e2",
    "yellow": "#efcfab",
    "teal": "#a7e1e8",
    "fg": "#d7d5cd",
    "fgLight": "#262029",
    "fgMuted": "#97958e",
    "fgMutedLight": "#5e5762",
    "comment": "#97958e",
    "commentLight": "#5e5762",
    "dark": "#423b45",
    "darkLight": "#e5e3db",
    "gutter": "#5e5762",
    "gutterLight": "#b7b5ad",
    "borderDim": "#5e5762",
    "borderDimLight": "#b7b5ad"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "#3d668f"
    },
    "secondary": {
      "dark": "purple",
      "light": "#6f5f9b"
    },
    "accent": {
      "dark": "teal",
      "light": "#32757c"
    },
    "error": "red",
    "warning": "orange",
    "success": "green",
    "info": "cyan",
    "text": {
      "dark": "fg",
      "light": "fgLight"
    },
    "textMuted": {
      "dark": "fgMuted",
      "light": "fgMutedLight"
    },
    "background": "none",
    "backgroundPanel": "none",
    "backgroundElement": "none",
    "border": {
      "dark": "borderDim",
      "light": "borderDimLight"
    },
    "borderActive": {
      "dark": "cyan",
      "light": "#32775a"
    },
    "borderSubtle": {
      "dark": "dark",
      "light": "darkLight"
    },
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": {
      "dark": "comment",
      "light": "commentLight"
    },
    "diffHunkHeader": {
      "dark": "cyan",
      "light": "#32775a"
    },
    "diffHighlightAdded": "green",
    "diffHighlightRemoved": "red",
    "diffAddedBg": "none",
    "diffRemovedBg": "none",
    "diffContextBg": "none",
    "diffLineNumber": {
      "dark": "gutter",
      "light": "gutterLight"
    },
    "diffAddedLineNumberBg": "none",
    "diffRemovedLineNumberBg": "none",
    "markdownText": {
      "dark": "fg",
      "light": "fgLight"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "#3d668f"
    },
    "markdownLink": {
      "dark": "cyan",
      "light": "#32775a"
    },
    "markdownLinkText": {
      "dark": "teal",
      "light": "#32757c"
    },
    "markdownCode": "green",
    "markdownBlockQuote": {
      "dark": "comment",
      "light": "commentLight"
    },
    "markdownEmph": "orange",
    "markdownStrong": "yellow",
    "markdownHorizontalRule": {
      "dark": "dark",
      "light": "darkLight"
    },
    "markdownListItem": {
      "dark": "blue",
      "light": "#3d668f"
    },
    "markdownListEnumeration": {
      "dark": "teal",
      "light": "#32757c"
    },
    "markdownImage": {
      "dark": "cyan",
      "light": "#32775a"
    },
    "markdownImageText": {
      "dark": "teal",
      "light": "#32757c"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fgLight"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "commentLight"
    },
    "syntaxKeyword": {
      "dark": "purple",
      "light": "#6f5f9b"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "#3d668f"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "fgLight"
    },
    "syntaxString": "green",
    "syntaxNumber": "orange",
    "syntaxType": {
      "dark": "cyan",
      "light": "#32775a"
    },
    "syntaxOperator": {
      "dark": "purple",
      "light": "#6f5f9b"
    },
    "syntaxPunctuation": {
      "dark": "comment",
      "light": "commentLight"
    }
  }
}
