{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "none": "none",
    "blue": "#7aa2f7",
    "cyan": "#7dcfff",
    "purple": "#bb9af7",
    "green": "#9ece6a",
    "orange": "#ff9e64",
    "red": "#f7768e",
    "yellow": "#e0af68",
    "teal": "#73daca",
    "fg": "#c0caf5",
    "fgLight": "#24283b",
    "fgMuted": "#9aa5ce",
    "fgMutedLight": "#5b627d",
    "comment": "#565f89",
    "commentLight": "#8a90a8",
    "dark": "#3b4261",
    "darkLight": "#d9dce8",
    "gutter": "#414868",
    "gutterLight": "#c0c6d8",
    "borderDim": "#4a5275",
    "borderDimLight": "#c7cbda",
    "panel": "#1f233580",
    "panelLight": "#edf1ffcc",
    "element": "#24283b66",
    "elementLight": "#e4e9f7cc",
    "diffAddBg": "#20303b",
    "diffAddBgLight": "#dff3e4",
    "diffRemoveBg": "#3a2230",
    "diffRemoveBgLight": "#f8e1e7",
    "diffContextBg": "#1a1f3088",
    "diffContextBgLight": "#eef2fbcc"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "#5877d8"
    },
    "secondary": {
      "dark": "purple",
      "light": "#7d63d1"
    },
    "accent": {
      "dark": "teal",
      "light": "#3f88a8"
    },
    "error": "red",
    "warning": "orange",
    "success": "green",
    "info": "cyan",
    "text": {
      "dark": "fg",
      "light": "fgLight"
    },
    "textMuted": {
      "dark": "fgMuted",
      "light": "fgMutedLight"
    },
    "background": "none",
    "backgroundPanel": {
      "dark": "panel",
      "light": "panelLight"
    },
    "backgroundElement": {
      "dark": "element",
      "light": "elementLight"
    },
    "border": {
      "dark": "borderDim",
      "light": "borderDimLight"
    },
    "borderActive": {
      "dark": "cyan",
      "light": "#5b7bd5"
    },
    "borderSubtle": {
      "dark": "dark",
      "light": "darkLight"
    },
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": {
      "dark": "comment",
      "light": "commentLight"
    },
    "diffHunkHeader": {
      "dark": "cyan",
      "light": "#5877d8"
    },
    "diffHighlightAdded": "green",
    "diffHighlightRemoved": "red",
    "diffAddedBg": {
      "dark": "diffAddBg",
      "light": "diffAddBgLight"
    },
    "diffRemovedBg": {
      "dark": "diffRemoveBg",
      "light": "diffRemoveBgLight"
    },
    "diffContextBg": {
      "dark": "diffContextBg",
      "light": "diffContextBgLight"
    },
    "diffLineNumber": {
      "dark": "gutter",
      "light": "gutterLight"
    },
    "diffAddedLineNumberBg": {
      "dark": "diffAddBg",
      "light": "diffAddBgLight"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diffRemoveBg",
      "light": "diffRemoveBgLight"
    },
    "markdownText": {
      "dark": "fg",
      "light": "fgLight"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "#4668cf"
    },
    "markdownLink": {
      "dark": "cyan",
      "light": "#3f88a8"
    },
    "markdownLinkText": {
      "dark": "teal",
      "light": "#2f7f76"
    },
    "markdownCode": "green",
    "markdownBlockQuote": {
      "dark": "comment",
      "light": "commentLight"
    },
    "markdownEmph": "orange",
    "markdownStrong": "yellow",
    "markdownHorizontalRule": {
      "dark": "dark",
      "light": "darkLight"
    },
    "markdownListItem": {
      "dark": "blue",
      "light": "#5877d8"
    },
    "markdownListEnumeration": {
      "dark": "teal",
      "light": "#2f7f76"
    },
    "markdownImage": {
      "dark": "cyan",
      "light": "#3f88a8"
    },
    "markdownImageText": {
      "dark": "teal",
      "light": "#2f7f76"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fgLight"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "commentLight"
    },
    "syntaxKeyword": {
      "dark": "purple",
      "light": "#7d63d1"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "#4668cf"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "fgLight"
    },
    "syntaxString": "green",
    "syntaxNumber": "orange",
    "syntaxType": {
      "dark": "cyan",
      "light": "#3f88a8"
    },
    "syntaxOperator": {
      "dark": "purple",
      "light": "#7d63d1"
    },
    "syntaxPunctuation": {
      "dark": "comment",
      "light": "commentLight"
    }
  }
}
