{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3 Coder (local)"
        },
        "qwen2.5-coder:0.5b": {
          "name": "Qwen2.5 Coder 0.5B (local, fast)"
        },
        "qwen2.5-coder:1.5b": {
          "name": "Qwen2.5 Coder 1.5B (local, balanced)"
        }
      }
    }
  },
  "model": "ollama/qwen3-coder",
  "small_model": "ollama/qwen2.5-coder:0.5b",
  "autoupdate": false,
  "share": "disabled",
  "permission": {
    "bash": "ask",
    "edit": "allow",
    "external_directory": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.pyc",
      "__pycache__/**",
      ".direnv/**",
      ".beads/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ]
}
