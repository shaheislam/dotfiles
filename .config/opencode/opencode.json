{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "models": {
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3 Coder (local)"
        },
        "qwen2.5-coder:0.5b": {
          "name": "Qwen2.5 Coder 0.5B (local, fast)"
        },
        "qwen2.5-coder:1.5b": {
          "name": "Qwen2.5 Coder 1.5B (local, balanced)"
        }
      }
    }
  },
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-pty",
    "opencode-vibeguard"
  ],
  "autoupdate": false,
  "share": "disabled",
  "permission": "allow",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.pyc",
      "__pycache__/**",
      ".direnv/**",
      ".beads/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ]
}
