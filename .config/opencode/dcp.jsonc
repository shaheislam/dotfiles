{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "commands": {
    "enabled": true,
    "protectedTools": []
  },
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true
  },
  "turnProtection": {
    "enabled": true,
    "turns": 4
  },
  "experimental": {
    "allowSubAgents": false,
    "customPrompts": false
  },
  "protectedFilePatterns": [
    "**/.plan.md",
    "**/.claude/CHANGELOG.md",
    "**/CLAUDE.md",
    "**/AGENTS.md"
  ],
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "nudgeForce": "soft",
    "nudgeFrequency": 5,
    "iterationNudgeThreshold": 15,
    "protectUserMessages": false,
    "modelMaxLimits": {
      "anthropic/claude-opus-4-7": "80%",
      "anthropic/claude-opus-4-8": "80%",
      "anthropic/claude-sonnet-4-6": "75%",
      "anthropic/claude-haiku-4-5": "75%",
      "openai/gpt-5.5": "75%"
    },
    "modelMinLimits": {
      "anthropic/claude-opus-4-7": "40%",
      "anthropic/claude-opus-4-8": "40%",
      "anthropic/claude-sonnet-4-6": "40%",
      "anthropic/claude-haiku-4-5": "40%",
      "openai/gpt-5.5": "40%"
    },
    "protectedTools": []
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": []
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": []
    }
  }
}
