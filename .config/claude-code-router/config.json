{
  "Providers": [
    {
      "name": "openrouter",
      "api_base_url": "https://openrouter.ai/api/v1/chat/completions",
      "api_key": "$OPENROUTER_API_KEY",
      "models": [
        "anthropic/claude-3.5-sonnet-20241022",
        "anthropic/claude-3.5-sonnet",
        "anthropic/claude-3-opus-20240229",
        "anthropic/claude-3-opus",
        "anthropic/claude-3.5-haiku-20241022",
        "anthropic/claude-3-haiku-20240307",
        "google/gemini-2.0-flash-exp",
        "google/gemini-2.0-flash-thinking-exp",
        "deepseek/deepseek-chat",
        "openai/gpt-4o",
        "openai/o1-preview",
        "meta-llama/llama-3.2-90b-vision-instruct"
      ]
    },
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com/v1/chat/completions",
      "api_key": "$DEEPSEEK_API_KEY",
      "models": [
        "deepseek-chat",
        "deepseek-reasoner"
      ]
    },
    {
      "name": "ollama",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "not-needed",
      "models": [
        "llama3.2",
        "qwen2.5-coder",
        "deepseek-r1"
      ]
    },
    {
      "name": "gemini",
      "api_base_url": "https://generativelanguage.googleapis.com/v1beta/chat/completions",
      "api_key": "$GEMINI_API_KEY",
      "models": [
        "gemini-2.0-flash-exp",
        "gemini-2.0-flash-thinking-exp-1219",
        "gemini-1.5-pro",
        "gemini-1.5-flash"
      ]
    }
  ],
  "Router": {
    "default": "openrouter,anthropic/claude-3.5-sonnet-20241022",
    "contextRouting": {
      "enabled": false,
      "rules": [
        {
          "pattern": "architecture|design|complex|debug",
          "provider": "openrouter",
          "model": "anthropic/claude-3-opus-20240229"
        },
        {
          "pattern": "code|implement|build|feature",
          "provider": "openrouter",
          "model": "anthropic/claude-3.5-sonnet-20241022"
        },
        {
          "pattern": "simple|quick|format|rename",
          "provider": "openrouter",
          "model": "anthropic/claude-3.5-haiku-20241022"
        },
        {
          "pattern": "explain|document|guide",
          "provider": "openrouter",
          "model": "anthropic/claude-3.5-sonnet-20241022"
        }
      ]
    }
  },
  "Settings": {
    "logLevel": "info",
    "maxTokens": 8192,
    "temperature": 0.7,
    "streamResponse": true
  }
}