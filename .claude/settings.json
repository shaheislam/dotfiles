{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": ""
  },
  "autoUpdatesChannel": "latest",
  "deniedMcpServers": [
    "claude_ai_Notion",
    "claude_ai_Linear",
    "claude_ai_Invideo"
  ],
  "effortLevel": "medium",
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true,
    "beads@steveyegge/beads": true,
    "code-review@claude-code-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "example-skills@anthropic-agent-skills": true,
    "explanatory-output-style@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "hookify@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "pua@pua-skills": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-code-plugins": true,
    "superpowers@superpowers-marketplace": true,
    "terraform-skill@antonbabenko": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000"
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "pua-skills": {
      "source": {
        "repo": "tanweai/pua",
        "source": "github"
      }
    }
  },
  "fileSuggestion": {
    "command": "fd --type f --hidden --exclude .git --exclude node_modules --exclude .claude/logs --exclude .claude/statsig",
    "type": "command"
  },
  "hooks": {
    "ConfigChange": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/config-change.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/macos_notification.py 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/log-notification.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/dotfiles/scripts/tmux/hooks/tmux-agent-notify.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/deepwiki-context.py 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "command": "timeout 5 entire hooks claude-code post-task 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "timeout 5 entire hooks claude-code post-todo 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "TodoWrite"
      },
      {
        "hooks": [
          {
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format.py 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/file-modified.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ci-lint-on-save.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/plan-watch.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-tool-failure.py 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/plan-persist.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/changelog-persist.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "timeout 5 entire hooks claude-code pre-task 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/use_bun.py",
            "type": "command"
          },
          {
            "command": "python3 ~/.claude/hooks/validate-bash.py",
            "type": "command"
          },
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ci-precommit.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/settings-edit-redirect.py\"; test -f \"$f\" || f=\"$HOME/.claude/hooks/settings-edit-redirect.py\"; test -f \"$f\" && python3 \"$f\" || true",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "timeout 10 entire hooks claude-code session-end 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/dotfiles/scripts/tmux/hooks/tmux-agent-end.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/scripts/harness/session-report.sh --json 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 60 bash ~/dotfiles/scripts/obsidian/session-synthesize.sh --cwd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/dotfiles/scripts/fix-hookify-imports.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 10 entire hooks claude-code session-start 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/dotfiles/scripts/tmux/hooks/tmux-agent-start.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/plugin-chmod-fix.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bd prime 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/work-detect.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/lsp-status.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/plan-resume.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/changelog-resume.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/skills/dream/count-session.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-reinject.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/cross-provider-bridge.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 10 entire hooks claude-code stop 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/dotfiles/scripts/tmux/hooks/tmux-agent-stop.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 60 bash ~/dotfiles/scripts/obsidian/session-synthesize.sh --cwd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 120 python3 ~/.claude/hooks/jfdi/session-end-extract.py 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/skills/dream/dream-hook.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/log-notification.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/log-notification.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/nvim-bridge.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 5 entire hooks claude-code user-prompt-submit 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bash ~/dotfiles/scripts/tmux/hooks/tmux-agent-prompt.sh 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "timeout 5 python3 ~/.claude/hooks/jfdi/prompt-inject-context.py 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/worktree-init.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/worktree-cleanup.sh 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "includeGitInstructions": false,
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bun install *)",
      "Bash(fish -c *)",
      "Bash(stow *)",
      "Bash(nix *)",
      "Bash(brew *)",
      "Bash(jq *)",
      "Bash(* --version)",
      "Bash(* --help)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/id_*)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Read(./.entire/metadata/**)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/dotfiles/scripts/claude-statusline.sh",
    "type": "command"
  }
}
